<Window x:Class="QuickWheel.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:QuickWheel.ViewModels"
        xmlns:loc="clr-namespace:QuickWheel.Services"
        mc:Ignorable="d"
        Title="{loc:Loc Key=WindowTitle_Settings}"
        Width="700"
        Height="500"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0" 
                    Style="{StaticResource MaterialDesignTabControl}"
                    Background="Transparent"
                    Margin="8">
            
            <!-- 快捷项管理 -->
            <TabItem Header="{loc:Loc Key=Tab_Shortcuts}" Style="{StaticResource MaterialDesignTabItem}">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DataGrid x:Name="ShortcutsGrid"
                                  ItemsSource="{Binding Shortcuts}"
                                  SelectedItem="{Binding SelectedShortcut}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  RowHeight="36"
                                  materialDesign:DataGridAssist.CellPadding="4,2"
                                  PreviewMouseLeftButtonDown="ShortcutsGrid_PreviewMouseLeftButtonDown"
                                  PreviewMouseMove="ShortcutsGrid_PreviewMouseMove"
                                  DragOver="ShortcutsGrid_DragOver"
                                  Drop="ShortcutsGrid_Drop"
                                  AllowDrop="True">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="IsTabStop" Value="False"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <!-- 选中时（包括悬停）保持选中颜色 -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E0E0E0"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <!-- 仅悬停且未选中时 -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="False"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <!-- 图标列 -->
                            <DataGridTemplateColumn Header="{loc:Loc Key=Col_Icon}" Width="50" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Icon}"
                                                FontSize="16"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Width="36"
                                                Height="28"
                                                Padding="0"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Click="IconButton_Click"
                                                Tag="{Binding}"
                                                Foreground="Black"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- 名称列 - 可编辑 -->
                            <DataGridTemplateColumn Header="{loc:Loc Key=Col_Name}" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Padding="4,0">
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Name}" 
                                                 VerticalAlignment="Center"
                                                 Padding="2,0"
                                                 BorderThickness="1"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- 目标路径列 - 可编辑 -->
                            <DataGridTemplateColumn Header="{loc:Loc Key=Col_Target}" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Padding="4,0">
                                            <TextBlock Text="{Binding Target}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Target}" 
                                                 VerticalAlignment="Center"
                                                 Padding="2,0"
                                                 BorderThickness="1"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- 空白列 - 用于选中整行 -->
                            <DataGridTemplateColumn Width="20" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
                        <Button Content="{loc:Loc Key=Btn_Add}"
                                Command="{Binding AddShortcutCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,4,0"
                                Padding="8,2"/>
                        <Button Content="{loc:Loc Key=Btn_Delete}"
                                Command="{Binding DeleteShortcutCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,4,0"
                                Padding="8,2"/>
                        <Button Content="{loc:Loc Key=Btn_Import}"
                                Command="{Binding ImportConfigCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,4,0"
                                Padding="8,2"/>
                        <Button Content="{loc:Loc Key=Btn_Export}"
                                Command="{Binding ExportConfigCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,0,4,0"
                                Padding="8,2"/>
                        <Button Content="{loc:Loc Key=Btn_Help}"
                                Click="HelpButton_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,2"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 热键与轮盘设置（合并） -->
            <TabItem Header="{loc:Loc Key=Tab_HotkeyAndWheel}" Style="{StaticResource MaterialDesignTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 热键设置 -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc Key=Hotkey_Current}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border Grid.Column="1" 
                                    Background="{DynamicResource MaterialDesignCardBackground}" 
                                    CornerRadius="2"
                                    Padding="8,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding HotkeyDisplay}" 
                                           FontSize="14" 
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2"
                                    Content="{Binding RecordButtonText}"
                                    Command="{Binding StartRecordingCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{Binding RecordButtonBrush}"
                                    Foreground="White"
                                    Padding="12,2"
                                    FontSize="12"/>
                        </Grid>
                        
                        <!-- 开机启动 -->
                        <CheckBox Grid.Row="1" 
                                  Content="{loc:Loc Key=Setting_StartWithWindows}"
                                  IsChecked="{Binding StartWithWindows}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="0,0,0,8"/>
                        
                        <!-- 通知设置 -->
                        <CheckBox Grid.Row="2" 
                                  Content="{loc:Loc Key=Setting_EnableNotifications}"
                                  IsChecked="{Binding EnableNotifications}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="0,0,0,8"/>
                        
                        <!-- 语言设置 -->
                        <Grid Grid.Row="3" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc Key=Setting_Language}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding SupportedLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      Width="120"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Separator Grid.Row="4" Margin="0,0,0,12"/>
                        
                        <!-- 颜色设置 -->
                        <TextBlock Grid.Row="5" Text="{loc:Loc Key=Wheel_Colors}" FontWeight="Bold" Margin="0,0,0,8"/>

                        <StackPanel Grid.Row="6" Orientation="Vertical" Margin="0,0,0,12">
                            <!-- 第一行：颜色选择 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <!-- 扇区颜色 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Loc Key=Wheel_ColorSector}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Command="{Binding SelectSectorColorCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Padding="0">
                                        <Rectangle Width="24" Height="16"
                                                   Fill="{Binding SectorColorBrush}"
                                                   Stroke="{DynamicResource MaterialDesignDivider}"
                                                   StrokeThickness="1"
                                                   RadiusX="2" RadiusY="2"/>
                                    </Button>
                                </StackPanel>

                                <!-- 高亮颜色 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Loc Key=Wheel_ColorHighlight}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Command="{Binding SelectHighlightColorCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Padding="0">
                                        <Rectangle Width="24" Height="16"
                                                   Fill="{Binding HighlightColorBrush}"
                                                   Stroke="{DynamicResource MaterialDesignDivider}"
                                                   StrokeThickness="1"
                                                   RadiusX="2" RadiusY="2"/>
                                    </Button>
                                </StackPanel>

                                <!-- 文字颜色 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc Key=Wheel_ColorText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Command="{Binding SelectTextColorCommand}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Padding="0">
                                        <Rectangle Width="24" Height="16"
                                                   Fill="{Binding TextColorBrush}"
                                                   Stroke="{DynamicResource MaterialDesignDivider}"
                                                   StrokeThickness="1"
                                                   RadiusX="2" RadiusY="2"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- 第二行：镂空和文字大小 -->
                            <StackPanel Orientation="Horizontal">
                                <!-- 镂空大小 -->
                                <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Loc Key=Wheel_InnerRadius}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding InnerRadiusRatio, StringFormat={}{0:P0}}"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"
                                                 FontSize="12"
                                                 Width="60"/>
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Key=Wheel_InnerRadiusHint}"
                                               FontSize="10"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- 文字大小 -->
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Loc Key=Wheel_TextSize}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding CenterTextSize, StringFormat={}{0:F0}}"
                                                 VerticalAlignment="Center"
                                                 Padding="4,2"
                                                 FontSize="12"
                                                 Width="60"/>
                                    </StackPanel>
                                    <TextBlock Text="{loc:Loc Key=Wheel_TextSizeHint}"
                                               FontSize="10"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            
            <!-- 关于与数据 -->
            <TabItem Header="{loc:Loc Key=Tab_About}" Style="{StaticResource MaterialDesignTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 应用信息 -->
                        <TextBlock Grid.Row="0" Text="{loc:Loc Key=About_Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Text="{loc:Loc Key=About_Subtitle}" FontSize="14" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,16"/>
                        
                        <TextBlock Grid.Row="2" Text="{loc:Loc Key=About_Version}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3" Text="{loc:Loc Key=About_Author}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="4" Text="{loc:Loc Key=About_Github}" FontSize="12" Margin="0,0,0,24"/>
                        
                        <Separator Grid.Row="5" Margin="0,0,0,16"/>
                        
                        <!-- 数据管理 -->
                        <TextBlock Grid.Row="6" Text="{loc:Loc Key=About_DataManagement}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        
                        <Grid Grid.Row="7">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 重置配置 -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Key=About_ResetConfig}" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{loc:Loc Key=About_ResetConfig_Desc}" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{loc:Loc Key=Btn_Reset}"
                                        Command="{Binding ResetConfigCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Padding="16,4"/>
                            </Grid>
                            
                            <!-- 清除所有数据 -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Key=About_ClearData}" FontSize="14" FontWeight="Medium" Foreground="Red"/>
                                    <TextBlock Text="{loc:Loc Key=About_ClearData_Desc}" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{loc:Loc Key=Btn_Clear}"
                                        Command="{Binding ClearAllDataCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="Red"
                                        BorderBrush="Red"
                                        Padding="16,4"/>
                            </Grid>
                        </Grid>
                        
                        <Separator Grid.Row="8" Margin="0,24,0,16"/>
                        
                        <!-- 开源协议 -->
                        <StackPanel Grid.Row="9" Orientation="Vertical">
                            <TextBlock Text="{loc:Loc Key=About_License}" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Loc Key=About_LicenseType}" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- 底部区域 -->
        <Grid Grid.Row="1" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 版本信息 -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc Key=AppName}"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{loc:Loc Key=Footer_Version}"
                           FontSize="11"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="{loc:Loc Key=Save}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,8,0"
                        Padding="16,4"/>
                <Button Content="{loc:Loc Key=Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="16,4"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
