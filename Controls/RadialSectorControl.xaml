<UserControl x:Class="QuickWheel.Controls.RadialSectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:QuickWheel.Controls"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="200"
             x:Name="Root">
    <UserControl.Resources>
        <controls:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <controls:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <Style x:Key="ContentStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        
        <!-- 缩放动画 -->
        <Storyboard x:Key="ScaleUpStoryboard">
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="ScaleDownStoryboard">
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- 阴影动画 -->
        <Storyboard x:Key="ShadowInStoryboard">
            <DoubleAnimation Storyboard.TargetName="SectorShadow"
                             Storyboard.TargetProperty="BlurRadius"
                             To="15" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SectorShadow"
                             Storyboard.TargetProperty="Opacity"
                             To="0.8" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="ShadowOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="SectorShadow"
                             Storyboard.TargetProperty="BlurRadius"
                             To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SectorShadow"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- 透明度动画 -->
        <Storyboard x:Key="OpacityInStoryboard">
            <DoubleAnimation Storyboard.TargetName="SectorPath"
                             Storyboard.TargetProperty="Opacity"
                             To="1.0" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="OpacityOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="SectorPath"
                             Storyboard.TargetProperty="Opacity"
                             To="0.6" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid>
        <Path x:Name="SectorPath"
              Fill="{Binding SectorFill, ElementName=Root}"
              Stroke="{Binding SectorStroke, ElementName=Root}"
              StrokeThickness="{Binding StrokeThickness, ElementName=Root}"
              Data="{Binding SectorGeometry, ElementName=Root}"
              IsHitTestVisible="True"
              Opacity="0.6">
            <Path.RenderTransform>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
            </Path.RenderTransform>
            <Path.RenderTransformOrigin>
                <Point X="0.5" Y="0.5"/>
            </Path.RenderTransformOrigin>
            <Path.Effect>
                <DropShadowEffect x:Name="SectorShadow"
                                  BlurRadius="0"
                                  Direction="0"
                                  ShadowDepth="0"
                                  Color="#FFFFFF"
                                  Opacity="0"/>
            </Path.Effect>
        </Path>
        
        <Canvas x:Name="ContentCanvas" IsHitTestVisible="False">
            <!-- 程序图标 -->
            <Image x:Name="IconImage"
                   Source="{Binding IconSource, ElementName=Root}"
                   Width="{Binding IconSize, ElementName=Root}"
                   Height="{Binding IconSize, ElementName=Root}"
                   Canvas.Left="{Binding IconX, ElementName=Root}"
                   Canvas.Top="{Binding IconY, ElementName=Root}"
                   Visibility="{Binding HasIconImage, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
                   Stretch="Uniform"/>
            
            <!-- Emoji 图标（当没有程序图标时显示） -->
            <TextBlock x:Name="IconText"
                       Text="{Binding Icon, ElementName=Root}"
                       FontSize="{Binding IconSize, ElementName=Root}"
                       Style="{StaticResource ContentStyle}"
                       Canvas.Left="{Binding IconX, ElementName=Root}"
                       Canvas.Top="{Binding IconY, ElementName=Root}"
                       Visibility="{Binding HasIconImage, ElementName=Root, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            
            <TextBlock x:Name="LabelText"
                       Text="{Binding Text, ElementName=Root}"
                       FontSize="{Binding TextSize, ElementName=Root}"
                       Style="{StaticResource ContentStyle}"
                       Canvas.Left="{Binding TextX, ElementName=Root}"
                       Canvas.Top="{Binding TextY, ElementName=Root}"
                       Visibility="{Binding ShowLabel, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Canvas>
    </Grid>
</UserControl>
